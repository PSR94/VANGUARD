# Core
VANGUARD_ENV=local
VANGUARD_LOG_LEVEL=INFO

# API
API_HOST=0.0.0.0
API_PORT=8080
API_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
DATASET_ROOT=/workspace/datasets

# Database and infra
POSTGRES_URL=postgresql+psycopg://vanguard:vanguard@postgres:5432/vanguard
REDIS_URL=redis://redis:6379/0
NEO4J_URI=bolt://neo4j:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=vanguardneo4j
OPENSEARCH_URL=http://opensearch:9200

# Provider
LLM_PROVIDER=deterministic-local
LLM_MODEL=vanguard-grounded-v1
